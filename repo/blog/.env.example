# ─────────────────────────────────────────────────────────
# Action Insights — Environment Variables
# Copy this file, rename to .env.local for local dev
# Add each variable in Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# ── Gmail SMTP ────────────────────────────────────────────
# Your Gmail address (the one that will SEND emails)
GMAIL_USER=you@gmail.com

# Gmail App Password — NOT your login password
# How to get it:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Search "App Passwords" → create one → name it "Action Insights"
#   4. Copy the 16-character password here (no spaces)
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# The email address that receives team notifications (can be same as GMAIL_USER or a team alias)
NOTIFY_EMAIL=team@yourcompany.com


# ── Microsoft Teams Webhook ───────────────────────────────
# How to get it:
#   1. In Teams, go to the channel you want notifications in
#   2. Click ··· → Connectors → "Incoming Webhook" → Configure
#   3. Give it a name ("Action Insights"), optionally upload a logo
#   4. Click Create → copy the webhook URL below
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/xxxxx


# ── Google Sheets ─────────────────────────────────────────
# The ID of your Google Sheet (from the URL: /spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Google Service Account email
# How to set up (one-time, ~5 min):
#   1. Go to console.cloud.google.com → New Project → "Action Insights Forms"
#   2. Enable "Google Sheets API" (APIs & Services → Library)
#   3. IAM & Admin → Service Accounts → Create Service Account
#      Name: "sheets-writer", Role: Editor
#   4. Click the service account → Keys → Add Key → JSON → Download
#   5. Open the JSON file — copy "client_email" value below
GOOGLE_SERVICE_ACCOUNT_EMAIL=sheets-writer@action-insights-forms.iam.gserviceaccount.com

# Private key from the same JSON file — copy the entire "private_key" value
# Important: keep the \n characters as-is, wrap the whole value in quotes in Vercel
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----\n"
