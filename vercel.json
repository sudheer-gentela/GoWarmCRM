{
  "trailingSlash": false,
  "functions": {
    "api/submit.js": {
      "maxDuration": 15
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "gowarmcrm.com"
        }
      ],
      "destination": "https://www.gowarmcrm.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "blog.gowarmcrm.com"
        }
      ],
      "destination": "https://www.gowarmcrm.com/blog/:path*",
      "permanent": true
    },
    {
      "source": "/v2",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/v2/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/v2/how-it-works",
      "destination": "/how-it-works",
      "permanent": true
    },
    {
      "source": "/v2/pricing",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/v2/problems",
      "destination": "/problems",
      "permanent": true
    },
    {
      "source": "/v2/diagnostic",
      "destination": "/diagnostic",
      "permanent": true
    },
    {
      "source": "/v2/insights",
      "destination": "/insights",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/website/index.html"
    },
    {
      "source": "/how-it-works",
      "destination": "/website/how-it-works.html"
    },
    {
      "source": "/pricing",
      "destination": "/website/pricing.html"
    },
    {
      "source": "/problems",
      "destination": "/website/problems.html"
    },
    {
      "source": "/about",
      "destination": "/website/about.html"
    },
    {
      "source": "/contact",
      "destination": "/website/contact.html"
    },
    {
      "source": "/diagnostic",
      "destination": "/website/diagnostic.html"
    },
    {
      "source": "/insights",
      "destination": "/website/insights.html"
    },
    {
      "source": "/platform-overview",
      "destination": "/website/platform-overview.html"
    },
    {
      "source": "/crm-integration",
      "destination": "/website/crm-integration.html"
    },
    {
      "source": "/salesforce-integration",
      "destination": "/website/salesforce-integration.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/:path*",
      "destination": "/blog/:path*.html"
    },
    {
      "source": "/sales-execution-platform",
      "destination": "/website/sales-execution-platform.html"
    },
    {
      "source": "/why-deals-go-dark",
      "destination": "/website/why-deals-go-dark.html"
    },
    {
      "source": "/pipeline-execution",
      "destination": "/website/pipeline-execution.html"
    },
    {
      "source": "/pipeline-data-accuracy",
      "destination": "/website/pipeline-data-accuracy.html"
    },
    {
      "source": "/sales-execution-platform-vs-crm",
      "destination": "/website/sales-execution-platform-vs-crm.html"
    },
    {
      "source": "/pipeline-leakage",
      "destination": "/website/pipeline-leakage.html"
    },
    {
      "source": "/sales-forecast-accuracy",
      "destination": "/website/sales-forecast-accuracy.html"
    },
    {
      "source": "/sales-execution-platform-for-saas",
      "destination": "/website/sales-execution-platform-for-saas.html"
    },
    {
      "source": "/crm-execution-gap",
      "destination": "/website/crm-execution-gap.html"
    },
    {
      "source": "/sales-rep-action-queue",
      "destination": "/website/sales-rep-action-queue.html"
    },
    {
      "source": "/execution-gap",
      "destination": "/website/execution-gap.html"
    },
    {
      "source": "/what-board-sees-pipeline",
      "destination": "/website/what-board-sees-pipeline.html"
    },
    {
      "source": "/index.md",
      "destination": "/markdown/index.md"
    },
    {
      "source": "/how-it-works.md",
      "destination": "/markdown/how-it-works.md"
    },
    {
      "source": "/pricing.md",
      "destination": "/markdown/pricing.md"
    },
    {
      "source": "/problems.md",
      "destination": "/markdown/problems.md"
    },
    {
      "source": "/execution-gap.md",
      "destination": "/markdown/execution-gap.md"
    },
    {
      "source": "/platform-overview.md",
      "destination": "/markdown/platform-overview.md"
    },
    {
      "source": "/crm-integration.md",
      "destination": "/markdown/crm-integration.md"
    },
    {
      "source": "/salesforce-integration.md",
      "destination": "/markdown/salesforce-integration.md"
    },
    {
      "source": "/about.md",
      "destination": "/markdown/about.md"
    },
    {
      "source": "/contact.md",
      "destination": "/markdown/contact.md"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Link",
          "value": "<https://www.gowarmcrm.com/sitemap.xml>; rel=\"sitemap\", <https://www.gowarmcrm.com/llms.txt>; rel=\"llms-txt\""
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)\\.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    }
  ]
}
